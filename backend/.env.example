NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://secureops:secureops_dev_password@localhost:5432/rcmc_secureops?schema=public

# setup.ps1 generates unique secrets in backend/.env.
JWT_ACCESS_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-another-random-secret-at-least-32-characters
JWT_REFRESH_TTL=7d

BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000
