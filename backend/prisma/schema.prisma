  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([module])
  @@index([severity])
  @@index([success])
  @@index([requestId])
  @@index([createdAt])
