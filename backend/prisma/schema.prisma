  @@map("emergency_procedures")
}

model IncidentProcedureStep {
  id            String    @id @default(uuid()) @db.Uuid
  incidentId    String    @db.Uuid
  procedureId   String    @db.Uuid
  stepIndex     Int
  stepTitle     String
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  completedById String?   @db.Uuid
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  incident    Incident           @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  procedure   EmergencyProcedure @relation(fields: [procedureId], references: [id], onDelete: Restrict)
  completedBy User?              @relation("IncidentProcedureStepCompleter", fields: [completedById], references: [id], onDelete: SetNull)

  @@unique([incidentId, procedureId, stepIndex])
  @@index([incidentId])
  @@index([procedureId])
  @@map("incident_procedure_steps")
}

model IncidentFollowUp {
  id           String                 @id @default(uuid()) @db.Uuid
  incidentId   String                 @db.Uuid
  title        String
  description  String                 @db.Text
  assignedToId String?                @db.Uuid
  dueAt        DateTime
  status       IncidentFollowUpStatus @default(OPEN)
  result       String?                @db.Text
  completedAt  DateTime?
  createdById  String                 @db.Uuid
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  deletedAt    DateTime?

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  assignedTo User?    @relation("IncidentFollowUpAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User     @relation("IncidentFollowUpCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([incidentId])
  @@index([assignedToId])
  @@index([status])
  @@index([dueAt])
  @@index([deletedAt])
  @@map("incident_follow_ups")
}

// ─── Sprint 18: Security Reports, Audit Log & KPIs ───

enum SavedReportType {
  DAILY_SECURITY
  SHIFT_REPORT
  HANDOVER_REPORT
  INCIDENT_REPORT
  EMERGENCY_REPORT
  PATROL_REPORT
  CHECKPOINT_REPORT
  CCTV_REFERRAL_REPORT
  PERMIT_REPORT
  VISITOR_REPORT
  VEHICLE_VIOLATION_REPORT
  RESPONSE_TIME_REPORT
  PERSONNEL_PERFORMANCE
  GROUP_PERFORMANCE
  SHIFT_PERFORMANCE
  LOCATION_ANALYSIS
  AUDIT_REPORT
  CUSTOM
}

enum SavedReportStatus {
  DRAFT
  GENERATED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
  FAILED
}

enum ReportClassification {
  INTERNAL
  CONFIDENTIAL
  HIGHLY_CONFIDENTIAL
}

enum ReportSectionType {
  SUMMARY
  KPI
  TABLE
  CHART
  TEXT
  TIMELINE
  RECOMMENDATIONS
  SIGNATURES
  ATTACHMENTS_LIST
}

enum ReportApprovalAction {
  SUBMITTED
  APPROVED
  REJECTED
  RETURNED_FOR_EDIT
  ARCHIVED
}

enum ReportScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
  END_OF_SHIFT
}

enum ReportAccessAction {
  VIEW
  GENERATE
  DOWNLOAD_PDF
  DOWNLOAD_CSV
  PRINT
  SUBMIT_FOR_APPROVAL
  APPROVE
  REJECT
  ARCHIVE
}

model SavedReport {
  id               String               @id @default(uuid()) @db.Uuid
  reportNumber     String
  title            String
  description      String?              @db.Text
  reportType       SavedReportType
  status           SavedReportStatus    @default(DRAFT)
  dateFrom         DateTime
  dateTo           DateTime
  shiftType        String?
  groupId          String?              @db.Uuid
  zoneId           String?              @db.Uuid
  userId           String?              @db.Uuid
  filtersJson      Json?
  summaryJson      Json?
  notes            String?              @db.Text
  recommendations  String?              @db.Text
  generatedById    String               @db.Uuid
  generatedAt      DateTime             @default(now())
  approvedById     String?              @db.Uuid
  approvedAt       DateTime?
  approvalNotes    String?              @db.Text
  classification   ReportClassification @default(INTERNAL)
  version          Int                  @default(1)
  parentReportId   String?              @db.Uuid
  filePath         String?
  fileMimeType     String?
  fileSize         Int?
  checksumSha256   String?
  csvPath          String?
  deletedAt        DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  generatedBy User          @relation("SavedReportGenerator", fields: [generatedById], references: [id], onDelete: Restrict)
  approvedBy  User?         @relation("SavedReportApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  group       ShiftGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  zone        SecurityZone? @relation("SavedReportZone", fields: [zoneId], references: [id], onDelete: SetNull)
  subjectUser User?         @relation("SavedReportSubject", fields: [userId], references: [id], onDelete: SetNull)
  parent      SavedReport?  @relation("SavedReportVersions", fields: [parentReportId], references: [id], onDelete: SetNull)
  versions    SavedReport[] @relation("SavedReportVersions")
  sections    ReportSection[]
  approvals   ReportApproval[]
  accessLogs  ReportAccessLog[]

  @@unique([reportNumber, version])
  @@index([reportType])
  @@index([status])
  @@index([generatedById])
  @@index([approvedById])
  @@index([dateFrom, dateTo])
  @@index([classification])
  @@index([deletedAt])
  @@map("saved_reports")
}

model ReportSection {
  id           String            @id @default(uuid()) @db.Uuid
  reportId     String            @db.Uuid
  sectionKey   String
  title        String
  sectionType  ReportSectionType
  orderIndex   Int               @default(0)
  contentJson  Json?
  textContent  String?           @db.Text
  isVisible    Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  report SavedReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId, orderIndex])
  @@map("report_sections")
}

model ReportApproval {
  id         String               @id @default(uuid()) @db.Uuid
  reportId   String               @db.Uuid
  approverId String               @db.Uuid
  action     ReportApprovalAction
  notes      String?              @db.Text
  createdAt  DateTime             @default(now())

  report   SavedReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  approver User        @relation("ReportApprovalActor", fields: [approverId], references: [id], onDelete: Restrict)

  @@index([reportId])
  @@index([approverId])
  @@index([createdAt])
  @@map("report_approvals")
}

model ReportSchedule {
  id             String                   @id @default(uuid()) @db.Uuid
  name           String
  reportType     SavedReportType
  frequency      ReportScheduleFrequency
  timeOfDay      String
  dayOfWeek      Int?
  dayOfMonth     Int?
  shiftType      String?
  groupId        String?                  @db.Uuid
  filtersJson    Json?
  recipientsJson Json?
  generatePdf    Boolean                  @default(true)
  generateCsv    Boolean                  @default(false)
  isActive       Boolean                  @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdById    String                   @db.Uuid
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deletedAt      DateTime?

  createdBy User        @relation("ReportScheduleCreator", fields: [createdById], references: [id], onDelete: Restrict)
  group     ShiftGroup? @relation("ReportScheduleGroup", fields: [groupId], references: [id], onDelete: SetNull)

  @@index([reportType])
  @@index([isActive])
  @@index([nextRunAt])
  @@index([deletedAt])
  @@map("report_schedules")
}

model ReportAccessLog {
  id         String             @id @default(uuid()) @db.Uuid
  reportId   String             @db.Uuid
  userId     String             @db.Uuid
  action     ReportAccessAction
  reason     String?            @db.Text
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime           @default(now())

  report SavedReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User        @relation("ReportAccessActor", fields: [userId], references: [id], onDelete: Restrict)

  @@index([reportId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("report_access_logs")
}

// ─── Sprint 19: Notifications, Communications & Tasks ───

model NotificationDelivery {
  id             String                      @id @default(uuid()) @db.Uuid
  notificationId String                      @db.Uuid
  userId         String                      @db.Uuid
  channel        NotificationDeliveryChannel
  status         NotificationDeliveryStatus  @default(PENDING)
  attemptedAt    DateTime                    @default(now())
  deliveredAt    DateTime?
  failureReason  String?                     @db.Text
  retryCount     Int                         @default(0)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([userId])
  @@index([channel, status])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id                 String               @id @default(uuid()) @db.Uuid
  userId             String               @db.Uuid
  category           NotificationCategory
  inAppEnabled       Boolean              @default(true)
  socketEnabled      Boolean              @default(true)
  pushEnabled        Boolean              @default(false)
  soundEnabled       Boolean              @default(false)
  quietHoursEnabled  Boolean              @default(false)
  quietHoursFrom     String?
  quietHoursTo       String?
  minimumPriority    NotificationPriority @default(LOW)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("notification_preferences")
}

model NotificationRule {
  id                       String               @id @default(uuid()) @db.Uuid
  name                     String
  eventType                String
  category                 NotificationCategory
  minimumSeverity          String?
  targetRolesJson          Json?
  targetGroupsJson         Json?
  notificationPriority     NotificationPriority @default(NORMAL)
  requiresAcknowledgement  Boolean              @default(false)
  reminderAfterMinutes     Int?
  escalationAfterMinutes   Int?
  maxReminders             Int                  @default(2)
  isActive                 Boolean              @default(true)
  createdById              String               @db.Uuid
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  deletedAt                DateTime?

  createdBy User @relation("NotificationRuleCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([eventType])
  @@index([category])
  @@index([isActive])
  @@index([deletedAt])
  @@map("notification_rules")
}

model InternalConversation {
  id                   String           @id @default(uuid()) @db.Uuid
  conversationNumber   String           @unique
  title                String?
  conversationType     ConversationType
  entityType           String?
  entityId             String?          @db.Uuid
  createdById          String           @db.Uuid
  isClosed             Boolean          @default(false)
  closedAt             DateTime?
  closedById           String?          @db.Uuid
  lastMessageAt        DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?

  createdBy    User                      @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Restrict)
  closedBy     User?                     @relation("ConversationCloser", fields: [closedById], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     InternalMessage[]

  @@index([conversationType])
  @@index([entityType, entityId])
  @@index([createdById])
  @@index([isClosed])
  @@index([deletedAt])
  @@map("internal_conversations")
}

model ConversationParticipant {
  id             String                      @id @default(uuid()) @db.Uuid
  conversationId String                      @db.Uuid
  userId         String                      @db.Uuid
  role           ConversationParticipantRole @default(MEMBER)
  joinedAt       DateTime                    @default(now())
  leftAt         DateTime?
  lastReadAt     DateTime?
  isMuted        Boolean                     @default(false)
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  conversation InternalConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_participants")
}

model InternalMessage {
  id               String              @id @default(uuid()) @db.Uuid
  conversationId   String              @db.Uuid
  senderId         String              @db.Uuid
  messageType      InternalMessageType @default(TEXT)
  content          String?             @db.Text
  replyToMessageId String?             @db.Uuid
  isEdited         Boolean             @default(false)
  editedAt         DateTime?
  isDeleted        Boolean             @default(false)
  deletedAt        DateTime?
  deletedById      String?             @db.Uuid
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  conversation InternalConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                 @relation("MessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  deletedBy    User?                @relation("MessageDeleter", fields: [deletedById], references: [id], onDelete: SetNull)
  replyTo      InternalMessage?     @relation("MessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies      InternalMessage[]    @relation("MessageReplies")
  attachments  MessageAttachment[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([isDeleted])
  @@map("internal_messages")
}

model MessageAttachment {
  id               String   @id @default(uuid()) @db.Uuid
  messageId        String   @db.Uuid
  fileName         String
  originalFileName String
  mimeType         String
  fileSize         Int
  storagePath      String
  uploadedById     String   @db.Uuid
  createdAt        DateTime @default(now())
  deletedAt        DateTime?

  message    InternalMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedBy User            @relation("MessageAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([messageId])
  @@index([uploadedById])
  @@index([deletedAt])
  @@map("message_attachments")
}

model TaskUpdate {
  id         String         @id @default(uuid()) @db.Uuid
  taskId     String         @db.Uuid
  userId     String         @db.Uuid
  updateType TaskUpdateType
  oldStatus  TaskStatus?
  newStatus  TaskStatus?
  message    String?        @db.Text
  createdAt  DateTime       @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskUpdateAuthor", fields: [userId], references: [id], onDelete: Restrict)

  @@index([taskId, createdAt])
  @@index([userId])
  @@map("task_updates")
}

model TaskEvidence {
  id               String   @id @default(uuid()) @db.Uuid
  taskId           String   @db.Uuid
  fileName         String
  originalFileName String
  mimeType         String
  fileSize         Int
  storagePath      String
  uploadedById     String   @db.Uuid
  description      String?  @db.Text
  createdAt        DateTime @default(now())
  deletedAt        DateTime?

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation("TaskEvidenceUploader", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([uploadedById])
  @@index([deletedAt])
  @@map("task_evidences")
}

// ─── Sprint 20: Mobile offline sync ─────────────────────────────
// Timezone reference for mobile clients: Asia/Riyadh

enum MobileSyncStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  REJECTED
  CONFLICT
  FAILED
}

enum MobileDevicePlatform {
  ANDROID
  IOS
  OTHER
}

model UserMobileDevice {
  id               String               @id @default(uuid()) @db.Uuid
  userId           String               @db.Uuid
  deviceUuid       String
  platform         MobileDevicePlatform
  appVersion       String
  deviceNameMasked String?
  lastLoginAt      DateTime?
  lastSeenAt       DateTime?
  isActive         Boolean              @default(true)
  pushCapability   Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncOperations MobileSyncOperation[]

  @@unique([userId, deviceUuid])
  @@index([userId])
  @@index([isActive])
  @@map("user_mobile_devices")
}

model MobileSyncOperation {
  id                  String           @id @default(uuid()) @db.Uuid
  userId              String           @db.Uuid
  deviceId            String?          @db.Uuid
  idempotencyKey      String
  operationType       String
  entityType          String
  localEntityId       String?
  serverEntityId      String?
  status              MobileSyncStatus
  requestHash         String?
  /// Small non-sensitive summary / result id only — never full secrets or tokens
  responseSummaryJson String?          @db.Text
  failureReason       String?
  clientCreatedAt     DateTime?
  receivedAt          DateTime         @default(now())
  processedAt         DateTime?
  createdAt           DateTime         @default(now())

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  device UserMobileDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@unique([userId, idempotencyKey])
  @@index([userId])
  @@index([status])
  @@index([receivedAt])
  @@index([deviceId])
  @@index([operationType])
  @@map("mobile_sync_operations")
}

