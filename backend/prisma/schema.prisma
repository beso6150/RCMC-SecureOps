model SecurityZone {
  id          String           @id @default(uuid()) @db.Uuid
  name        String
  code        String           @unique
  description String?          @db.Text
  zoneType    SecurityZoneType
  parentId    String?          @db.Uuid
  floorNumber Int?
  mapX        Float            @default(0)
  mapY        Float            @default(0)
  width       Float            @default(100)
  height      Float            @default(80)
  color       String           @default("#0f766e")
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  parent       SecurityZone?  @relation("ZoneTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     SecurityZone[] @relation("ZoneTree")
  checkpoints  SecurityCheckpoint[]
  personnelLocations PersonnelLocation[]
  fieldAlerts  FieldAlert[]
  incidents    Incident[]     @relation("IncidentZone")
  violations   VehicleViolation[] @relation("ViolationZone")
  securityPermits SecurityPermit[]
  securityReferrals SecurityReferral[]
  savedReports SavedReport[] @relation("SavedReportZone")

  @@index([parentId])
  @@index([zoneType])
  @@index([isActive])
  @@map("security_zones")
}

model SecurityCheckpoint {
  id                String          @id @default(uuid()) @db.Uuid
  name              String
  code              String          @unique
  description       String?         @db.Text
  zoneId            String          @db.Uuid
  latitude          Float?
  longitude         Float?
  mapX              Float           @default(0)
  mapY              Float           @default(0)
  checkpointType    CheckpointType  @default(GENERAL)
  qrCodeValue        String          @unique
  nfcTagValue       String?
  requiredForPatrol Boolean         @default(true)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  zone           SecurityZone            @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  routePoints    PatrolRouteCheckpoint[]
  visits         PatrolCheckpointVisit[]
  incidents      Incident[]              @relation("IncidentCheckpoint")
  violations     VehicleViolation[]      @relation("ViolationCheckpoint")
  securityReferrals SecurityReferral[]

  @@index([zoneId])
  @@index([checkpointType])
  @@index([isActive])
  @@map("security_checkpoints")
}

model PatrolRoute {
  id                       String   @id @default(uuid()) @db.Uuid
  name                     String
  description              String?  @db.Text
  shiftType                String?
  groupId                  String?  @db.Uuid
  estimatedDurationMinutes Int      @default(60)
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  group       ShiftGroup?             @relation(fields: [groupId], references: [id], onDelete: SetNull)
  checkpoints PatrolRouteCheckpoint[]
  sessions    PatrolSession[]

  @@index([groupId])
  @@index([isActive])
  @@map("patrol_routes")
}

model PatrolRouteCheckpoint {
  id                      String   @id @default(uuid()) @db.Uuid
  routeId                 String   @db.Uuid
  checkpointId            String   @db.Uuid
  orderIndex              Int
  expectedMinutesFromStart Int     @default(0)
  isRequired              Boolean  @default(true)
  instructions            String?  @db.Text
  createdAt               DateTime @default(now())

  route      PatrolRoute        @relation(fields: [routeId], references: [id], onDelete: Cascade)
  checkpoint SecurityCheckpoint @relation(fields: [checkpointId], references: [id], onDelete: Restrict)

  @@unique([routeId, checkpointId])
  @@unique([routeId, orderIndex])
  @@index([checkpointId])
  @@map("patrol_route_checkpoints")
}

model PatrolSession {
  id                 String              @id @default(uuid()) @db.Uuid
  routeId            String              @db.Uuid
  assignedUserId     String?             @db.Uuid
  assignedById       String?             @db.Uuid
  shiftSessionId     String?             @db.Uuid
  groupId            String?             @db.Uuid
  status             PatrolSessionStatus @default(SCHEDULED)
  scheduledStartAt   DateTime
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?             @db.Text
  notes              String?             @db.Text
  priority           Int                 @default(100)
  overrideRestingGroup Boolean           @default(false)
  overrideReason     String?             @db.Text
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  route         PatrolRoute             @relation(fields: [routeId], references: [id], onDelete: Restrict)
  assignedUser  User?                   @relation("PatrolSessionAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedBy    User?                   @relation("PatrolSessionAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  shiftSession  ShiftSession?            @relation(fields: [shiftSessionId], references: [id], onDelete: SetNull)
  group         ShiftGroup?             @relation(fields: [groupId], references: [id], onDelete: SetNull)
  visits        PatrolCheckpointVisit[]
  incidents     Incident[]              @relation("IncidentPatrolSession")
  fieldAlerts   FieldAlert[]

  @@index([routeId])
  @@index([assignedUserId])
  @@index([status])
  @@index([scheduledStartAt])
  @@index([groupId])
  @@map("patrol_sessions")
}

model PatrolCheckpointVisit {
  id                String                   @id @default(uuid()) @db.Uuid
  patrolSessionId   String                   @db.Uuid
  checkpointId      String                   @db.Uuid
  visitedById       String                   @db.Uuid
  visitedAt         DateTime                 @default(now())
  verificationMethod PatrolVerificationMethod @default(MANUAL)
  mapX              Float?
  mapY              Float?
  notes             String?                  @db.Text
  attachmentUrl     String?
  status            PatrolVisitStatus        @default(VERIFIED)
  clientSyncId      String?                  @unique
  createdAt         DateTime                 @default(now())

  patrolSession PatrolSession      @relation(fields: [patrolSessionId], references: [id], onDelete: Cascade)
  checkpoint    SecurityCheckpoint @relation(fields: [checkpointId], references: [id], onDelete: Restrict)
  visitedBy     User               @relation("PatrolVisitActor", fields: [visitedById], references: [id], onDelete: Restrict)

  @@unique([patrolSessionId, checkpointId])
  @@index([patrolSessionId])
  @@index([checkpointId])
  @@index([visitedById])
  @@index([visitedAt])
  @@map("patrol_checkpoint_visits")
}

model PersonnelLocation {
  id         String                   @id @default(uuid()) @db.Uuid
  userId     String                   @db.Uuid
  zoneId     String?                  @db.Uuid
  mapX       Float
  mapY       Float
  accuracy   Float?
  source     PersonnelLocationSource  @default(MOBILE)
  recordedAt DateTime                 @default(now())
  expiresAt  DateTime?
  isCurrent  Boolean                  @default(true)

  user User          @relation("PersonnelLocations", fields: [userId], references: [id], onDelete: Cascade)
  zone SecurityZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([userId, isCurrent])
  @@index([userId, recordedAt])
  @@index([zoneId])
  @@index([recordedAt])
  @@map("personnel_locations")
}

model FieldAlert {
  id              String            @id @default(uuid()) @db.Uuid
  title           String
  description     String            @db.Text
  alertType       FieldAlertType
  severity        FieldAlertSeverity @default(MEDIUM)
  zoneId          String?           @db.Uuid
  assignedUserId  String?           @db.Uuid
  assignedGroupId String?           @db.Uuid
  incidentId      String?           @db.Uuid
  patrolSessionId String?           @db.Uuid
  mapX            Float?
  mapY            Float?
  status          FieldAlertStatus  @default(NEW)
  acknowledgedAt  DateTime?
  resolvedAt      DateTime?
  resolutionNote  String?           @db.Text
  createdById     String            @db.Uuid
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

