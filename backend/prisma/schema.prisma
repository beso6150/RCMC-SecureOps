  assignedGroup  ShiftGroup?    @relation(fields: [assignedGroupId], references: [id], onDelete: SetNull)
  incident       Incident?      @relation("FieldAlertIncident", fields: [incidentId], references: [id], onDelete: SetNull)
  patrolSession  PatrolSession? @relation(fields: [patrolSessionId], references: [id], onDelete: SetNull)
  createdBy      User           @relation("FieldAlertCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([severity])
  @@index([alertType])
  @@index([assignedUserId])
  @@index([zoneId])
  @@index([patrolSessionId])
  @@index([createdAt])
  @@map("field_alerts")
}

