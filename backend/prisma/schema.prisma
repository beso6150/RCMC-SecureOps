  @@index([severity])
  @@index([referralType])
  @@index([createdById])
  @@index([assignedUserId])
  @@index([assignedGroupId])
  @@index([zoneId])
  @@index([occurredAt])
  @@index([deletedAt])
  @@map("security_referrals")
}

model SecurityReferralAttachment {
