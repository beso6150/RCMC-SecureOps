// ─── RBAC ───────────────────────────────────────────────────────

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  nameEn      String
  nameAr      String
  description String?   @db.Text
  isSystem    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users           User[]
  rolePermissions RolePermission[]

  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  resource    String
  action      String
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  rolePermissions    RolePermission[]
  permissionPolicies PermissionPolicy[]

  @@unique([resource, action])
  @@index([resource])
  @@index([deletedAt])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Uuid
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

/// Editable policy hooks for dashboard (conditions JSON)
model PermissionPolicy {
  id           String    @id @default(uuid()) @db.Uuid
  permissionId String    @db.Uuid
  name         String
  description  String?   @db.Text
  /// e.g. { "effect": "deny"|"allow", "when": { "field": "phone", "unless": "context.incidentHandling" } }
  conditions   Json
  priority     Int       @default(100)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@index([permissionId, isActive])
  @@index([deletedAt])
  @@map("permission_policies")
}

// ─── Org structure ──────────────────────────────────────────────

model Department {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  nameEn      String
  nameAr      String
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users User[]
  hosts Host[]

  @@index([deletedAt])
  @@map("departments")
}

model Building {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  nameEn    String
  nameAr    String
  address   String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  floors Floor[]

  @@index([deletedAt])
  @@map("buildings")
}

model Floor {
  id         String    @id @default(uuid()) @db.Uuid
  buildingId String    @db.Uuid
  code       String
  nameEn     String
  nameAr     String
  level      Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  building     Building      @relation(fields: [buildingId], references: [id], onDelete: Restrict)
  locations    Location[]
  meetingRooms MeetingRoom[]
  visitors     Visitor[]
  incidents    Incident[]

  @@unique([buildingId, code])
  @@index([buildingId])
  @@index([deletedAt])
  @@map("floors")
}

model Location {
  id          String    @id @default(uuid()) @db.Uuid
  floorId     String    @db.Uuid
  code        String
  nameEn      String
  nameAr      String
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  floor             Floor              @relation(fields: [floorId], references: [id], onDelete: Restrict)
  visitors          Visitor[]
  vehiclePermits    VehiclePermit[]
  vehicleViolations VehicleViolation[]
  patrols           Patrol[]
  incidents         Incident[]
  complaints        Complaint[]

  @@unique([floorId, code])
  @@index([floorId])
  @@index([deletedAt])
  @@map("locations")
}

model Shift {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  nameEn      String
  nameAr      String
  startTime   String
  endTime     String
  timezone    String    @default("Asia/Riyadh")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users     User[]
  incidents Incident[]

  @@index([deletedAt])
  @@map("shifts")
}

model ShiftGroup {
  id        String         @id @default(uuid()) @db.Uuid
  code      ShiftGroupCode @unique
  nameAr    String
  nameEn    String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  deletedAt DateTime?

  users          User[]
  sessions       ShiftSession[]
  patrolRoutes   PatrolRoute[]
  patrolSessions PatrolSession[]
  fieldAlerts    FieldAlert[]
  permitShares   PermitShare[]
  securityReferrals SecurityReferral[]
  incidentAssignments IncidentAssignment[]
  incidentTasks  IncidentTask[]
  incidentsAssigned Incident[] @relation("IncidentAssignedGroup")
  savedReports   SavedReport[]
  reportSchedules ReportSchedule[] @relation("ReportScheduleGroup")
  tasksAssigned  Task[] @relation("TaskAssignedGroup")

  @@index([deletedAt])
  @@map("shift_groups")
}

model ShiftCycleConfig {
  id               String   @id @default(uuid()) @db.Uuid
  cycleStartDate   DateTime @db.Date
  morningStartTime String   @default("06:00")
  morningEndTime   String   @default("18:00")
  eveningStartTime String   @default("18:00")
  eveningEndTime   String   @default("06:00")
  timezone         String   @default("Asia/Riyadh")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("shift_cycle_configs")
}

model ShiftSession {
  id          String             @id @default(uuid()) @db.Uuid
  kind        ShiftKind
  groupId     String             @db.Uuid
  cycleDay    Int
  serviceDate DateTime           @db.Date
  startsAt    DateTime
  endsAt      DateTime
  status      ShiftSessionStatus @default(OPEN)
  closedAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  group          ShiftGroup      @relation(fields: [groupId], references: [id], onDelete: Restrict)
  handover       ShiftHandover?
  alerts         ShiftAlertLog[]
  patrolSessions PatrolSession[]

  @@unique([kind, startsAt])
  @@index([groupId])
  @@index([status])
  @@index([serviceDate])
  @@map("shift_sessions")
}

model ShiftHandover {
  id                   String             @id @default(uuid()) @db.Uuid
  sessionId            String             @unique @db.Uuid
  outgoingSupervisorId String             @db.Uuid
  incomingSupervisorId String             @db.Uuid
  openIncidentsCount   Int                @default(0)
  closedIncidentsCount Int                @default(0)
  patrolsCount         Int                @default(0)
  violationsCount      Int                @default(0)
  notes                String?            @db.Text
  equipmentNotes       String?            @db.Text
  handoverStatus       HandoverStepStatus @default(PENDING)
  takeoverStatus       HandoverStepStatus @default(PENDING)
  handoverApprovedAt   DateTime?
  takeoverApprovedAt   DateTime?
  handoverApprovedById String?            @db.Uuid
  takeoverApprovedById String?            @db.Uuid
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  session              ShiftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  outgoingSupervisor   User         @relation("HandoverOutgoing", fields: [outgoingSupervisorId], references: [id], onDelete: Restrict)
  incomingSupervisor   User         @relation("HandoverIncoming", fields: [incomingSupervisorId], references: [id], onDelete: Restrict)
  handoverApprovedBy   User?        @relation("HandoverApprovedBy", fields: [handoverApprovedById], references: [id], onDelete: SetNull)
  takeoverApprovedBy   User?        @relation("TakeoverApprovedBy", fields: [takeoverApprovedById], references: [id], onDelete: SetNull)

  @@index([outgoingSupervisorId])
  @@index([incomingSupervisorId])
  @@map("shift_handovers")
}

model ShiftAlertLog {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @db.Uuid
  alertKey  String
  sentAt    DateTime @default(now())

  session ShiftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, alertKey])
  @@index([sessionId])
  @@map("shift_alert_logs")
}

// ─── Users ──────────────────────────────────────────────────────

model User {
  id                String             @id @default(uuid()) @db.Uuid
  nationalId        String             @unique
  employeeNumber    String             @unique
  fullName          String
  email             String             @unique
  phone             String?
  jobTitle          String?
  passwordHash      String
  status            UserStatus         @default(PENDING_FIRST_LOGIN)
  isFirstLogin      Boolean            @default(true)
  lastLoginAt       DateTime?
  roleId            String             @db.Uuid
  departmentId      String?            @db.Uuid
  shiftId           String?            @db.Uuid
  groupId           String?            @db.Uuid
  operationalStatus OperationalStatus  @default(OFF_DUTY)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  role          Role           @relation(fields: [roleId], references: [id], onDelete: Restrict)
  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  shift         Shift?         @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  group         ShiftGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]

  hostedVisitors         Visitor[]          @relation("VisitorHost")
  hostsAsRecord          Host[]             @relation("HostUser")
  visitHistoryActions    VisitHistory[]     @relation("VisitHistoryActor")
  visitNotifications     VisitNotification[] @relation("VisitNotificationRecipient")
  vehiclePermitsApproved VehiclePermit[]    @relation("PermitApprover")
  violationsCreated      VehicleViolation[] @relation("ViolationCreator")
  violationsAsSupervisor VehicleViolation[] @relation("ViolationSupervisor")
  violationsAsOperator   VehicleViolation[] @relation("ViolationCctvOperator")
  patrolsAssigned        Patrol[]           @relation("PatrolAssignee")
  incidentsReported      Incident[]         @relation("IncidentReporter")
  incidentsAssigned      Incident[]         @relation("IncidentAssignee")
  incidentsAsSupervisor  Incident[]         @relation("IncidentSupervisor")
  incidentsAsOpsManager  Incident[]         @relation("IncidentOpsManager")
  incidentsAssignedBy    Incident[]         @relation("IncidentAssignedBy")
  incidentsAcknowledged  Incident[]         @relation("IncidentAcknowledgedBy")
  incidentsAssessed      Incident[]         @relation("IncidentAssessedBy")
  incidentsClosed        Incident[]         @relation("IncidentClosedBy")
  incidentComments       IncidentComment[]  @relation("IncidentCommentAuthor")
  incidentHistoryActions IncidentHistory[]  @relation("IncidentHistoryActor")
  incidentAttachmentsUploaded IncidentAttachment[] @relation("IncidentAttachmentUploader")
  incidentAssignmentsMade IncidentAssignment[] @relation("IncidentAssignmentAssigner")
  incidentAssignmentsReceived IncidentAssignment[] @relation("IncidentAssignmentAssignee")
  incidentNotesCreated   IncidentNote[]     @relation("IncidentNoteAuthor")
  incidentContactsMade   IncidentContactLog[] @relation("IncidentContactActor")
  incidentTasksAssigned  IncidentTask[]     @relation("IncidentTaskAssignee")
  incidentTasksCreated   IncidentTask[]     @relation("IncidentTaskCreator")
  incidentTasksCompleted IncidentTask[]     @relation("IncidentTaskCompleter")
  incidentFollowUpsAssigned IncidentFollowUp[] @relation("IncidentFollowUpAssignee")
  incidentFollowUpsCreated IncidentFollowUp[] @relation("IncidentFollowUpCreator")
  emergencyProceduresCreated EmergencyProcedure[] @relation("EmergencyProcedureCreator")
  incidentProcedureStepsCompleted IncidentProcedureStep[] @relation("IncidentProcedureStepCompleter")
  savedReportsGenerated SavedReport[] @relation("SavedReportGenerator")
  savedReportsApproved SavedReport[] @relation("SavedReportApprover")
  savedReportsAsSubject SavedReport[] @relation("SavedReportSubject")
  reportApprovals ReportApproval[] @relation("ReportApprovalActor")
  reportSchedulesCreated ReportSchedule[] @relation("ReportScheduleCreator")
  reportAccessLogs ReportAccessLog[] @relation("ReportAccessActor")
  complaintsSubmitted    Complaint[]        @relation("ComplaintSubmitter")
  complaintsReviewed     Complaint[]        @relation("ComplaintReviewer")
  notifications          Notification[]
  notificationsSent      Notification[]     @relation("NotificationSender")
  notificationsAcknowledged Notification[]  @relation("NotificationAcknowledger")
  tasksAssigned          Task[]             @relation("TaskAssignee")
  tasksCreated           Task[]             @relation("TaskAssigner")
  tasksCompleted         Task[]             @relation("TaskCompleter")
  tasksAuthored          Task[]             @relation("TaskCreator")
  taskUpdates            TaskUpdate[]       @relation("TaskUpdateAuthor")
  taskEvidencesUploaded  TaskEvidence[]     @relation("TaskEvidenceUploader")
  notificationPreferences NotificationPreference[]
  notificationRulesCreated NotificationRule[] @relation("NotificationRuleCreator")
  notificationDeliveries NotificationDelivery[]
  conversationsCreated   InternalConversation[] @relation("ConversationCreator")
  conversationsClosed    InternalConversation[] @relation("ConversationCloser")
  conversationParticipants ConversationParticipant[]
  messagesSent           InternalMessage[]  @relation("MessageSender")
  messagesDeleted        InternalMessage[]  @relation("MessageDeleter")
  messageAttachmentsUploaded MessageAttachment[] @relation("MessageAttachmentUploader")
  responseTimesAsActor   ResponseTime[]     @relation("ResponseTimeActor")
  auditLogs              AuditLog[]
  cameraRequestsCreated  CameraRequest[]    @relation("CameraRequestRequester")
  cameraRequestsAssigned CameraRequest[]    @relation("CameraRequestOperator")
  handoversOutgoing      ShiftHandover[]    @relation("HandoverOutgoing")
  handoversIncoming      ShiftHandover[]    @relation("HandoverIncoming")
  handoversApproved      ShiftHandover[]    @relation("HandoverApprovedBy")
  takeoversApproved      ShiftHandover[]    @relation("TakeoverApprovedBy")
  patrolSessionsAssigned PatrolSession[]    @relation("PatrolSessionAssignee")
  patrolSessionsAssignedBy PatrolSession[]  @relation("PatrolSessionAssigner")
  patrolVisits           PatrolCheckpointVisit[] @relation("PatrolVisitActor")
  personnelLocations     PersonnelLocation[] @relation("PersonnelLocations")
  fieldAlertsAssigned    FieldAlert[]       @relation("FieldAlertAssignee")
  fieldAlertsCreated     FieldAlert[]       @relation("FieldAlertCreator")
  securityPermitsCreated SecurityPermit[]   @relation("SecurityPermitCreator")
  permitSharesSent       PermitShare[]      @relation("PermitShareSender")
  permitSharesReceived   PermitShare[]      @relation("PermitShareRecipient")
  securityReferralsCreated SecurityReferral[] @relation("SecurityReferralCreator")
  securityReferralsAssigned SecurityReferral[] @relation("SecurityReferralAssignee")
  securityReferralsAssignedBy SecurityReferral[] @relation("SecurityReferralAssigner")
  securityReferralAttachments SecurityReferralAttachment[] @relation("SecurityReferralAttachmentUploader")
  securityReferralUpdates SecurityReferralUpdate[] @relation("SecurityReferralUpdateAuthor")
  referralResponses      ReferralResponse[] @relation("ReferralResponder")
  mobileDevices          UserMobileDevice[]
  mobileSyncOperations   MobileSyncOperation[]

  @@index([roleId])
  @@index([departmentId])
  @@index([shiftId])
  @@index([groupId])
  @@index([operationalStatus])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── Visitors & Hosts ───────────────────────────────────────────

model Host {
  id                      String                      @id @default(uuid()) @db.Uuid
  userId                  String?                     @db.Uuid
  employeeNumber          String                      @unique
  employeeName            String
  departmentId            String?                     @db.Uuid
  phone                   String?
  communicationPreference HostCommunicationPreference @default(WHATSAPP)
  whatsappEnabled         Boolean                     @default(true)
  phoneCallEnabled        Boolean                     @default(false)
  email                   String?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  deletedAt               DateTime?

  user     User?       @relation("HostUser", fields: [userId], references: [id], onDelete: SetNull)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  visitors Visitor[]

  @@index([userId])
  @@index([departmentId])
  @@index([employeeNumber])
  @@index([deletedAt])
  @@map("hosts")
}

model MeetingRoom {
  id        String    @id @default(uuid()) @db.Uuid
  floorId   String    @db.Uuid
  code      String
  nameEn    String
  nameAr    String
  capacity  Int?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  floor    Floor     @relation(fields: [floorId], references: [id], onDelete: Restrict)
  visitors Visitor[]
  incidents Incident[]

  @@unique([floorId, code])
  @@index([floorId])
  @@index([deletedAt])
  @@map("meeting_rooms")
}

model Visitor {
  id              String          @id @default(uuid()) @db.Uuid
  visitorName     String
  nationalId      String?
