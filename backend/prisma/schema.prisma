// RCMC SecureOps — PostgreSQL / Prisma
// Visible app: المشرف الأمني الذكي
// Sprint 02 schema + Sprint 03 IAM (RefreshToken, PermissionPolicy)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

