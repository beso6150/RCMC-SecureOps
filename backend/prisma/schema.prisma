  floorNumber        Int?
  cameraCode         String?
  occurredAt         DateTime                 @default(now())
  createdById        String                   @db.Uuid
  assignedUserId     String?                  @db.Uuid
  assignedGroupId    String?                  @db.Uuid
  assignedById       String?                  @db.Uuid
  assignedAt         DateTime?
  receivedAt         DateTime?
  startedAt          DateTime?
  arrivedAt          DateTime?
  resolvedAt         DateTime?
  closedAt           DateTime?
  rejectedAt         DateTime?
  cancelledAt        DateTime?
  escalationLevel    Int                      @default(0)
  escalatedAt        DateTime?
  escalationReason   String?                  @db.Text
  resolutionSummary  String?                  @db.Text
  rejectionReason    String?                  @db.Text
  cancellationReason String?                  @db.Text
  needsFollowUp      Boolean                  @default(false)
  notes              String?                  @db.Text
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deletedAt          DateTime?

  zone          SecurityZone?               @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  checkpoint    SecurityCheckpoint?         @relation(fields: [checkpointId], references: [id], onDelete: SetNull)
  createdBy     User                        @relation("SecurityReferralCreator", fields: [createdById], references: [id], onDelete: Restrict)
  assignedUser  User?                       @relation("SecurityReferralAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedGroup ShiftGroup?                 @relation(fields: [assignedGroupId], references: [id], onDelete: SetNull)
  assignedBy    User?                       @relation("SecurityReferralAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
